"id":"873","slug":"racing","name":"赛车","description":"适合您一次生活在四分之一英里之外的产品。"},"climbing":{"id":"872","slug":"climbing","name":"爬","description":"当重力无法将您制服时，请查看这些产品，以帮助您克服困境。"},"college-sports":{"id":"871","slug":"college-sports","name":"高校体育","description":"为NCAA粉丝群提供动力的大学体育工具：类别预测器、游泳池、社交热点追踪器、加密货币交易、支持、招聘和运动员网络。"},"community":{"id":"870","slug":"community","name":"社区","description":"社区收集帮助人们建立联系、创建和发展的工具-论坛、发布、时事通讯、支付、人工智能工作流程以及面向构建者和粉丝的聚会。"},"chat-rooms":{"id":"869","slug":"chat-rooms","name":"聊天室","description":"聊天室是实时语音文本、语音和视频链接社区、人工智能助手、Web 3钱包、交易中心以及咨询和协作的空间。"},"personal-shopper":{"id":"868","slug":"personal-shopper","name":"Personal shopper","description":"为您选择的个人购物工具：AI礼物查找器、造型和护肤品挑选、降价提醒、生态节俭、自动送礼、创客市场契合度检查。"},"food-delivery":{"id":"867","slug":"food-delivery","name":"送餐","description":"食品配送涵盖订购应用程序、杂货机器人、卡车司机送餐、家庭烹饪和植物性膳食、餐厅工具，以及帮助您快速找到食物的搜索。"},"physics":{"id":"866","slug":"physics","name":"物理","description":"物理学解释了物质、运动和力。为世界各地的学生和专业人士探索多物理场分析、公式查找、虚拟电路实验室和空间跟踪。"},"security":{"id":"865","slug":"security","name":"安全","description":"安全性涵盖保护登录、数据和支付的工具：身份、密码管理器、合规自动化、网络防御和具有企业控制的人工智能。"},"encryption":{"id":"864","slug":"encryption","name":"加密","description":"加密工具锁定电子邮件、聊天、文件和云数据，帮助团队和个人跨应用程序和工作流程安全地共享、存储和管理秘密。"},"password-manager":{"id":"863","slug":"password-manager","name":"密码管理器","description":"保护和自动填充登录、生成强密码、管理2FA并为个人、团队和注重隐私的组织启用审计共享的工具。"},"vpn":{"id":"862","slug":"vpn","name":"VPN","description":"虚拟专用网络（VPN）加密浏览、突破地理限制并连接车队。产品涵盖移动隐私、家庭路由器和WireGuard网状网络。"},"webcam":{"id":"861","slug":"webcam","name":"Webcam","description":"网络摄像头工具将摄像头变成录制、流媒体和研究视频编辑、托管、增强、眼动追踪和手机作为摄像头的中心"},"photo-editing":{"id":"860","slug":"photo-editing","name":"照片编辑","description":"了解图像工作流程如何结合在一起：平台托管人工智能模型、应用程序执行文本到图像、背景剪切、精确编辑、3D/视频渲染、批处理API。"},"dslrs":{"id":"859","slug":"dslrs","name":"DSLRs","description":"单反：帮助您捕捉、控制和共享的装备和应用程序。预计AI助手、无线遥控器、租赁、智能手机控制、360和即时打印。"},"video-cameras":{"id":"858","slug":"video-cameras","name":"摄像机","description":"捕获、传输和重新利用视频的工具：移动捕获、网络摄像头、屏幕记录器、特效以及适合创作者、销售和DIY修饰的设备上人工智能。"},"video":{"id":"857","slug":"video","name":"视频","description":"视频包括会面、录制屏幕、生成剪辑、转录语音和制作互动演示的工具，帮助团队、创作者和开发人员协作。"},"aquarium":{"id":"856","slug":"aquarium","name":"水族馆","description":"水族馆技术将智能水箱、清洁机器人、发光展品和任务跟踪器配对，为爱好者和学校简化护理、教授科学、美化空间。"},"local-news":{"id":"855","slug":"local-news","name":"当地新闻","description":"当地新闻整合了社区信息工具：查找附近的工作、比较候选人、跟踪土耳其物价上涨、查看独立报道以及在当地分享。"},"health-news":{"id":"854","slug":"health-news","name":"健康新闻","description":"健康新闻涵盖了转移护理的工具：症状检查、依从性提醒、研究摘要、成像和笔记技术、疫情跟踪以及计费成本削减。"},"tech-news":{"id":"853","slug":"tech-news","name":"科技新闻","description":"科技新闻涵盖了我们如何创造和消费技术：分析、自动化、时事通讯、人工智能社区、付费墙解锁和面向制造商的民间微博。"},"political-news":{"id":"852","slug":"political-news","name":"政治新闻","description":"政治新闻工具，为选民和分析师跟踪政策、比较候选人、评级来源、主持辩论、绕过付费墙和精心设计解释。"},"camping":{"id":"851","slug":"camping","name":"露营","description":"露营涵盖寻找地点、规划路线、管理装备和提供游戏时间的工具和住宿，帮助露营者、货车爱好者和团队共同探索户外活动。"},"survival":{"id":"850","slug":"survival","name":"生存","description":"生存工具涵盖危机援助、同伴支持、心肺复苏急救、线下专业知识和安全检查，帮助人们在混乱中做好准备、做出反应并保持联系。"},"plants":{"id":"849","slug":"plants","name":"植物","description":"植物涵盖种植、识别和购买绿色植物的工具;花园追踪器;树木和根部的游戏;通过流媒体重新造林;以及一款受自然启发的工艺品。"},"gps":{"id":"848","slug":"gps","name":"GPS","description":"GPS拾取器可跟踪锻炼、标记照片、欺骗位置以及为地理定位媒体和地图提供动力。计划旅行、管理GPX以及发现或共享附近的景点。"},"hiking":{"id":"847","slug":"hiking","name":"徒步旅行","description":"徒步旅行跨越了规划和导航;这些工具查找步道、线下工作、跟踪高峰、管理装备、根据天气量身定制想法、指导自助游、增强照片。"},"nature":{"id":"846","slug":"nature","name":"性质","description":"帮助您探索、观察和放松的自然工具：识别鸟类、追踪野生动物、寻找海滩、播放声音景观以及建立日常可持续习惯。"},"social-media-marketing":{"id":"845","slug":"social-media-marketing","name":"社交媒体营销","description":"社交媒体营销通过帖子和视频推广品牌;这些工具创建和本地化剪辑、记录屏幕、安排和跟踪、货币化和集成。"},"affiliate-marketing":{"id":"844","slug":"affiliate-marketing","name":"联盟营销","description":"跟踪链接、运行推荐计划和规模增长的联盟营销工具。专为SaaS和创作者构建：归因、支出、内容和社区。"},"event-marketing":{"id":"843","slug":"event-marketing","name":"事件营销","description":"活动营销使用工具来规划、宣传、举办和衡量活动，以建立潜在客户和社区，从场馆和人工智能内容到票务、AR和民意调查。"},"influencer-marketing":{"id":"842","slug":"influencer-marketing","name":"网红营销","description":"此类别涵盖寻找创作者、跟踪社交电商、管理合作伙伴关系和在线销售的工具，帮助品牌大规模开展数据驱动的活动。"},"marketing-calendar":{"id":"841","slug":"marketing-calendar","name":"营销日历","description":"营销日历组织活动、内容和事件;这些工具安排帖子、协调团队、自动化外展并快速报告结果。"},"marketing-attribution":{"id":"840","slug":"marketing-attribution","name":"营销归因","description":"营销归因跟踪哪些接触点推动了销售。这些工具将广告、影响者、QR链接、位置和Shopify数据链接到ROAS和用户旅程。"},"marketing-automation":{"id":"839","slug":"marketing-automation","name":"营销自动化","description":"营销自动化工具为使用人工智能、集成和无代码构建器的增长团队简化潜在客户捕获、内容和电子邮件活动以及应用程序工作流程。"},"spirituality":{"id":"838","slug":"spirituality","name":"灵性","description":"融合信仰练习、正念和成长的灵性工具：醒来祈祷、学习经文、冥想、获得人工智能指导、用声音专注。保持正轨。"},"diy":{"id":"837","slug":"diy","name":"DIY","description":"DIY意味着自己做项目。这种组合可以帮助您创建、销售、修复和个性化人工智能创意、专家帮助、支付、自我修饰、爱好指南。"},"military":{"id":"836","slug":"military","name":"军事","description":"军事主题涵盖国防技术和救援工作：从用于快速任务的垂直起降侦察无人机到指导捐款支持乌克兰的精心策划的目录。"},"career":{"id":"835","slug":"career","name":"职业生涯","description":"探索有助于寻找职位、招聘和成长的职业工具：网络、简历定制、筛选、薪资、项目跟踪和创造者收入。"},"lgbtq":{"id":"834","slug":"lgbtq","name":"LGBTQ+","description":"LGBTQ+连接、安全和健康工具。寻找匹配、跟踪性健康、报告仇恨、寻找安全空间、获得过渡帮助、庆祝骄傲。"},"babies":{"id":"833","slug":"babies","name":"婴儿","description":"婴儿：规划、照顾和好奇未来的工具。从命名和生育选项到跟踪器和睡眠指南，以及未来面孔的人工智能预览。"},"family":{"id":"832","slug":"family","name":"家庭","description":"关怀、联系和记住的家庭工具：护理人员提醒、私人照片日记、为孩子做好准备的故事制作者和无压力的个人贷款跟踪。"},"pregnancy":{"id":"831","slug":"pregnancy","name":"妊娠","description":"从计划到产后为您提供支持的怀孕选择：人工智能聊天、当地社区、分娩呼吸、营养、糖尿病提示、喂养和尿布帮助。"},"toddlers":{"id":"830","slug":"toddlers","name":"幼儿","description":"此类别涵盖适合父母和幼儿的早期学习工具：互动故事、无屏幕游戏以及用于建立联系、言语和思考的闪存卡。"},"toys":{"id":"829","slug":"toys","name":"玩具","description":"玩具融合了有趣的科技和DIY乐趣：STEM编码、虚拟宠物、乐高工具、着色应用程序以及适合家庭、收藏家和教育工作者的物理数字游戏。"},"home-services":{"id":"828","slug":"home-services","name":"家庭服务","description":"家庭服务捆绑了管理家庭及其企业的工具：搬家、房地产投资、安全入住、日程安排、预订、增长工具。"},"furniture":{"id":"827","slug":"furniture","name":"家具","description":"家居用品和收件箱：人工智能价格检查、设计工具、DIY准备单品、人体工程学装备以及适合购物者、房东和设计师的租赁选择。"},"home-security":{"id":"826","slug":"home-security","name":"家庭安全","description":"家庭安全保护人员、财产和网络：访问控制、摄像头设置、家庭和个人检查、防火墙、家庭和团队的背景检查。"},"interior-design":{"id":"825","slug":"interior-design","name":"室内设计","description":"室内设计工具规划、可视化和布置空间：人工智能渲染器、3D扫描、家具策展、协作以及房主和专业人士的灵感。"},"home-theater":{"id":"824","slug":"home-theater","name":"家庭影院","description":"家庭影院收集丰富的家庭音响设备，例如通过蓝牙、UPSYS或Roon-ready系统将黑胶唱片传输到多房间扬声器的无线转盘。"},"home-improvement":{"id":"823","slug":"home-improvement","name":"家装","description":"规划、升级和管理您的空间的家居装修工具：DIY指导、室内设计、能源和碳跟踪、资产库存、舒适度升级。"},"neighborhood":{"id":"822","slug":"neighborhood","name":"邻域","description":"邻里工具可以帮助您在当地生活、联系和决定--寻找住房和室友、参加当地聊天、评估危险、探索城市、靠近朋友。"},"home-office":{"id":"821","slug":"home-office","name":"内政部","description":"家庭办公中心：实现生产力和工作空间创意的装备和应用程序-管理PDF、编写、捕获屏幕、同步剪贴板、调整显示屏和休息。"},"weightlifting":{"id":"820","slug":"weightlifting","name":"举重","description":"举重通过结构性训练增强力量。这些工具为运动员、初学者和教练规划锻炼、赛道设置、休息时间并量身定制营养。"},"running":{"id":"819","slug":"running","name":"运行","description":"单独或与朋友一起运行跟踪、游戏化和指导里程的应用程序。为初学者和赛车手寻找节奏工具、节奏节拍、数据同步、NFT奖励。"},"fitness":{"id":"818","slug":"fitness","name":"健身","description":"发现将健康的日常生活转化为行动的工具：跟踪锻炼、接受人工智能指导、加入社区、赚取奖励以及监测睡眠/心率变异--甚至可以通过为任何人提供戒指。"},"health":{"id":"817","slug":"health","name":"健康","description":"为日常护理提供信息和支持的健康工具：寻找答案、跟踪心率变异性和皮肤变化、提高注意力和心理健康，并为游牧民提供海外护理。"},"cell-phone":{"id":"816","slug":"cell-phone","name":"手机","description":"手机必需品涵盖使通话、照片、搜索和旅行数据成为工作重点的设备、操作系统和服务，以及虚拟号码和业务。"},"sensors":{"id":"815","slug":"sensors","name":"传感器","description":"传感器为跟踪空间、安全和服务器占用率的工具提供动力-计算桌子、信标发送警报，并且代理监视IT、人力资源和组的备份。"},"computers":{"id":"814","slug":"computers","name":"计算机","description":"计算机将云人工智能、设备上技术、开发平台、办公应用程序和收件箱工具捆绑在一起--适合日常计算的一切--适合编码人员、团队和创作者。"},"tablet":{"id":"813","slug":"tablet","name":"平板","description":"平板电脑是一款便携式触摸电脑，可用于多功能应用程序。这些选择涵盖了针对学习者、专业人士和团队的创造力、教育、办公工具和电子墨水阅读。"},"appliances":{"id":"812","slug":"appliances","name":"电器","description":"电器涵盖更智能的家庭助手（啤酒酿造器、加热器、始终打开的显示器）以及用于发现、共享或资助它们的应用程序。适合厨师、粉丝、环保家庭。"},"animation":{"id":"811","slug":"animation","name":"动画","description":"探索适合设计师、开发人员和创作者的Web、应用程序和视频的动画工具-AI编辑、载体SON运动、关键帧和设计工具出口。"},"design-templates":{"id":"810","slug":"design-templates","name":"设计模板","description":"设计模板是跨开发和无代码工具的UI和工作流程精心策划的模块，帮助团队和独奏更快地原型设计并交付有凝聚力的应用程序。"},"design-resources":{"id":"809","slug":"design-resources","name":"设计资源","description":"加速UI和内容创建的设计资源：UI库、模板、载体、动画、库存图像、AI工具和创作者的灵感。"},"logo-design":{"id":"808","slug":"logo-design","name":"徽标设计","description":"徽标设计捆绑了创建和部署品牌标记的工具：人工智能生成器、经过审查的设计师、资产库、招聘中心、网站建设者、API和市场。"},"ux-design":{"id":"807","slug":"ux-design","name":"UX设计","description":"用户体验（UX）设计塑造了人们使用应用程序和网站的方式。这些工具涵盖UI布局、原型、3D、研究、分析、入职和开发移交。"},"wireframing":{"id":"806","slug":"wireframing","name":"线框图","description":"线框将想法映射到简单的屏幕和用户流程中，然后再进行代码。这些工具结合了设计师、PM和团队的网站地图、实体模型和原型。"},"web-design":{"id":"805","slug":"web-design","name":"网页设计","description":"网页设计涵盖将创意从像素转化为生产的工具：视觉构建器、无代码应用程序制作器、UI套件、授权/支付以及设计师、开发人员使用的CMS。"},"graphic-design":{"id":"804","slug":"graphic-design","name":"平面设计","description":"平面设计将想法转化为视觉效果。这些工具涵盖人工智能编辑、股票、照片清理、徽标、网站、自由职业者和销售服务营销人员、中小企业、初创公司和创作者。"},"3d-modeling":{"id":"803","slug":"3d-modeling","name":"3D建模","description":"3D建模将想法转化为游戏、电影和AR/VR的虚拟对象。这种组合涵盖创建工具、人工智能资产生成器、引擎、图形处理器和协作中心。"},"design":{"id":"802","slug":"design","name":"设计","description":"这里的设计涵盖了为创作者和团队构建、原型制作、展示和销售数字体验-UI/UX、图形、应用程序、新闻稿和合规计费。"},"graphics":{"id":"801","slug":"graphics","name":"图形","description":"图形涵盖创建、渲染、编辑和运送视觉效果的工具，从图形处理器和艺术应用程序到人工智能剪纸、实体模型工具、反馈和数字资产许可。"},"farming":{"id":"800","slug":"farming","name":"农业","description":"农业工具涵盖作物分析、物联网、任务应用程序、融资、交易、投资、研究和农场到户销售，帮助种植者规划、监控和赚钱。"},"dieting":{"id":"799","slug":"dieting","name":"节食","description":"通过人工智能计划膳食、记录食物并跟踪营养的节食工具。应用程序减少浪费、定制卡路里并指导家庭厨师和健康书呆子的寿命。"},"nutrition":{"id":"798","slug":"nutrition","name":"营养","description":"营养工具可记录膳食、计划菜单、分析补充剂并使饮食适合过敏或禁食。非常适合注重健康的用户、家庭厨师和学习者。"},"alcohol":{"id":"797","slug":"alcohol","name":"醇","description":"探索酒精工具：AR混合指南，配方生成器，派对游戏，ABV计算器，以及为家庭调酒师和新饮酒者提供的清醒挑战。"},"dining":{"id":"796","slug":"dining","name":"用餐","description":"餐饮涵盖烹饪、外出就餐和接待：计划膳食、抢餐桌、分摊账单、聘请厨师、跟踪零食、运送食物和经营餐厅的工具。"},"credit-card":{"id":"795","slug":"credit-card","name":"信用卡","description":"探索可以发行卡、跟踪费用并加速商业支出、旅行积分、现金返还和消费信贷的奖励的信用卡工具。"},"banking":{"id":"794","slug":"banking","name":"银行","description":"银行业务意味着为初创公司、自由职业者、夫妇和加密货币用户接受付款、运行账户、增加储蓄以及发送跨境转账的服务。"},"budgeting":{"id":"793","slug":"budgeting","name":"预算编制","description":"预算整合了跟踪支出、计划旅行、预测业务现金流、自动合规以及为个人和中小企业构建的安全银行业务的应用程序。"},"personal-finance":{"id":"792","slug":"personal-finance","name":"个人理财","description":"个人理财工具可帮助您赚取、跟踪和增长资金：针对个人、创作者和初创公司的预算、银行业务、股权、支付和社会投资。"},"fundraising":{"id":"791","slug":"fundraising","name":"筹款","description":"创始人的筹款工具：管理股权、银行和法律文档，通过热情的介绍寻找投资者，与分析分享推介文件，并指导甲板。"},"mixed-reality":{"id":"790","slug":"mixed-reality","name":"混合现实","description":"混合现实（MR）将数字内容与现实生活融为一体。这些工具为创作者、品牌、健身和教育构建、流媒体和玩AR/VR体验。"},"live-events":{"id":"789","slug":"live-events","name":"现场活动","description":"Live Events收集工具来主持流媒体、吸引观众和安排时间-从24/7广播到表情符号反馈、可购物流媒体、音乐ID和演出促销。"},"ticketing":{"id":"788","slug":"ticketing","name":"票务","description":"票务工具涵盖活动销售和支持订单-销售座位、管理预订和路线请求。预计表格、付款、Discord/HR关系、NFT、搜索API。"},"sporting-events":{"id":"787","slug":"sporting-events","name":"体育赛事","description":"体育赛事工具，可在现场和在线上规划、绘制地图、售票和举办比赛。适合需要时间表、更新的组织者、教练、俱乐部和游戏玩家。"},"theater":{"id":"786","slug":"theater","name":"剧院","description":"为舞台提供动力的戏剧工具：更快地编写剧本、用提示排练即兴表演以及管理活动和票务。适合剧作家、演员、组织者。"},"concerts":{"id":"785","slug":"concerts","name":"音乐会","description":"音乐会涵盖查找歌曲、跟踪艺术家、计划节日、比较门票的工具。更智能地在线或虚拟地发现演出、管理活动并抢占座位。"},"memes":{"id":"784","slug":"memes","name":"模因","description":"模因是一口大小的笑话和反应。该中心涵盖人工智能制作者、声音片段、搜索、货币化--供创作者和营销人员创建、查找、分享的工具"},"pop-culture":{"id":"783","slug":"pop-culture","name":"流行文化","description":"这里的流行文化意味着我们用日常应用程序交换的共享故事、游戏和视觉效果，以换取琐事、引言、发球台、塔罗牌、图像编辑、趋势和身份洞察。"},"online-learning":{"id":"782","slug":"online-learning","name":"在线学习","description":"在线学习通过网络工具提供技能：人工智能导师、队列课程、发现引擎和知识中心，帮助专业人士和学生进行研究和创造。"},"school":{"id":"781","slug":"school","name":"学校","description":"支持学习、教学和生活的学校选择：人工智能笔记、考试准备、大学指导、家庭学校提示、焦点工具和协作地图。"},"hacking":{"id":"780","slug":"hacking","name":"黑客","description":"道德安全工具可测试应用程序和网络、运行错误赏金、审计SSH密钥、揭示数据暴露以及将团队与经过审查的专家和人工智能扫描联系起来。"},"development-language":{"id":"779","slug":"development-language","name":"开发语言","description":"探索构建和学习编码背后的堆栈：Web框架、Web 3基础设施、人工智能助手、CSS工具、设计编码、课程和面试实践"},"sdk":{"id":"778","slug":"sdk","name":"SDK","description":"SDK捆绑了API和工具来快速构建应用程序;这些选择涵盖了托管，AI，auth，实时协作，语音和数据，供开发人员发布现代Web。"},"change-management":{"id":"777","slug":"change-management","name":"变更管理","description":"变更管理协调人员、工具和政策，以便顺利更新土地。这些选择大规模处理反馈、工作流程、基础设施、招聘和团队习惯"},"statistical-analysis":{"id":"776","slug":"statistical-analysis","name":"统计分析","description":"这里的统计分析工具将原始点击、聊天、谜题和调查转化为分析师和PM的趋势-仪表板、基准、更明智的决策。"},"data-visualization":{"id":"775","slug":"data-visualization","name":"数据可视化","description":"数据可视化将指标转化为产品、网络和销售数据的图表和仪表板，涵盖行为、发布、保留和隐私优先报告。"},"business-intelligence":{"id":"774","slug":"business-intelligence","name":"商业智能","description":"商业智能（BI）工具将公司数据转化为分析师、SaaS团队、销售和支持的跨分析、仪表板和人工智能驱动的操作。"},"data-science":{"id":"773","slug":"data-science","name":"数据科学","description":"数据科学将原始数据转化为决策。这些工具涵盖分析、人工智能应用程序、仪表板、隐私优先构建以及分析师和工程师的验证。"},"database":{"id":"772","slug":"database","name":"数据库","description":"一个数据库中心，供应用程序存储、同步、查询和保护数据覆盖无服务器PostGER、载体搜索、ORM、无/低代码构建器和边缘交付。"},"data":{"id":"771","slug":"data","name":"数据","description":"收集、分析、移动和保护信息的数据工具-涵盖分析、人工智能、无服务器商店、CDC、集成和隐私-适合PM、开发人员、营销人员"},"monetization":{"id":"770","slug":"monetization","name":"货币化","description":"货币化工具将内容和软件转化为收入：时事通讯、赞助商、付费墙、会员资格以及创作者、品牌和SaaS团队的使用计费。"},"crm":{"id":"769","slug":"crm","name":"CRM","description":"CRM工具集中联系人，自动化销售，营销和支持，同步电子邮件，LinkedIn和WhatsApp以跟踪管道并提高保留率。"},"human-resources":{"id":"768","slug":"human-resources","name":"人力资源","description":"这里的人力资源工具涵盖招聘、薪资、合规、反馈、培训和支付支持全球团队、远程工作和视频引导的入职。加上承包商。"},"construction":{"id":"767","slug":"construction","name":"建设","description":"建筑工具从蓝图到建筑：测量空间，离线地图，注释计划，估计成本，管理工作，并找到预制房屋。"},"consulting":{"id":"766","slug":"consulting","name":"咨询","description":"咨询小组为创始人和团队提供专家建议、实时或跨行业SEO审计、开发支持、人工智能工作流程、战略视觉效果以及网络工具"},"operations":{"id":"765","slug":"operations","name":"操作","description":"运营工具简化了业务的运营方式：自动化工作流程、财务和法律、培训团队、管理会议、资产以及将数据转化为KPI洞察。"},"accounting":{"id":"764","slug":"accounting","name":"会计","description":"为初创公司、中小企业自动化簿记、计费、税收和报告的会计工具。包括AI分类、银行/Stripe同步、账单OCR、工作流程。"},"coding-books":{"id":"763","slug":"coding-books","name":"程序设计图书","description":"通过适合孩子到专业人士的书籍、指南、互动工具和游戏学习编码。构建JavaScript、SQL、React应用程序、调试、后台和数据库技能。"},"textbooks":{"id":"762","slug":"textbooks","name":"教科书","description":"这里的教科书涵盖安全课程材料、编码课程、人工智能导师和教学、保护内容并帮助学生和教育工作者学习的考试准备工具。"},"business-books":{"id":"761","slug":"business-books","name":"商业书籍","description":"商业书籍通过工具和指南展示了实际战略：CRM、支持收件箱、研究中心、营销见解、电子商务、为创始人策划的读物。"},"defi":{"id":"760","slug":"defi","name":"DeFi","description":"DeFi让您像货币市场一样使用加密货币。这种组合涵盖了赌注收益率、DEC分析、钱包和安全性、人工智能投资组合工具、开发基础设施和链上身份。"},"blockchain":{"id":"759","slug":"blockchain","name":"区块链","description":"区块链意味着去中心化的应用程序和资产。这些工具帮助您构建、浏览、分析和发展Web 3-跨开发、基础设施、钱包、身份、社区。"},"cryptocurrency":{"id":"758","slug":"cryptocurrency","name":"加密货币","description":"加密货币工具帮助接受支付、跟踪市场、通过API进行交易、管理NFT、启用ID并增加为交易员、创作者和企业打造的受众。"},"dapp":{"id":"757","slug":"dapp","name":"dApp","description":"去中心化应用程序是我们今天使用的应用程序的点对点表兄弟。当您不希望您的数据被单一公司锁定时，请查看这些基于区块链的替代方案，以赋予您对信息的所有权。 "},"dao":{"id":"756","slug":"dao","name":"道","description":"去中心化的自治组织正在召集人们自我组织并以更开放的方式实现目标"},"bitcoin":{"id":"755","slug":"bitcoin","name":"比特币","description":"让您购买、储蓄、消费、赚取和跟踪的比特币工具：钱包、BCA应用程序、奖励卡、市场数据、游戏和聊天技巧-专为新人和专业人士打造。"},"ethereum":{"id":"754","slug":"ethereum","name":"以太坊","description":"以太坊为可编程货币提供动力。这些工具可以帮助您管理ETH、以收益率为赌注、查找dApp、启动NFT、部署为创作者和交易员构建的合同。"},"clothing":{"id":"753","slug":"clothing","name":"服装","description":"探索服装工具和平台：利用人工智能设计、服装团队、获得优质优惠、支持更好的姿势、3D试穿以及调查购物者的合身度。"},"cosmetics":{"id":"752","slug":"cosmetics","name":"化妆品","description":"化妆品工具可帮助您选择和个性化化妆品--成分扫描仪、创作者精选和气味匹配器--适合初学者、爱好者和专业人士。"},"streetwear":{"id":"751","slug":"streetwear","name":"街头服饰","description":"街头服饰融合了时尚、艺术和创作者文化。这些工具和市场帮助设计、展示和在线向粉丝销售定制服装和运动鞋。"},"hip-hop":{"id":"749","slug":"hip-hop","name":"嘻哈","description":"嘻哈音乐关乎节奏、文字游戏和影响力。这些选择帮助MC制定更紧凑的诗句，并帮助营销人员跟踪营销活动、构建应用程序并扩大受众。"},"comedy":{"id":"748","slug":"comedy","name":"喜剧","description":"喜剧在这里意味着激发笑声和社交游戏的工具-浏览模因、笑话和人工智能烘焙，制作恶作剧创意和有趣的礼物，并吸引观众。"},"classical-music":{"id":"747","slug":"classical-music","name":"古典音乐","description":"探索古典音乐工具，帮助您练习、作曲、流媒体表演、测试琐事以及共享服务学生、教育工作者、表演者和歌迷。"},"concert":{"id":"746","slug":"concert","name":"音乐会","description":"探索现场音乐活动的工具：它们集中阵容、实时更新并制定个人服务-非常适合音乐节观众、组织者和粉丝。"},"tuning":{"id":"745","slug":"tuning","name":"调谐","description":"这里的调音意味着优化音频创作和播放。工具清理噪音，修复音高，构建网站播放器，流站，并为创作者生成SFX。"},"radio":{"id":"744","slug":"radio","name":"无线电","description":"这里的广播意味着流媒体音频：直播站、播客、焦点节拍和创作者工具。它适合听众、远程工作人员和直播节目主持人。"},"live-music":{"id":"743","slug":"live-music","name":"现场音乐","description":"现场音乐意味着您参加的表演;这些工具可以帮助您查找演出、比较门票、计划节日、发现艺术家、直播广播并结识音乐家。"},"electronic-music":{"id":"742","slug":"electronic-music","name":"电子音乐","description":"电子音乐工具可让您创作、排序、生成、发现和共享曲目-从人工智能歌曲制作者和鼓机到播放列表和远程语音实验室。"},"calligraphy":{"id":"741","slug":"calligraphy","name":"书法","description":"书法是巧妙的写作。这些工具可以教授剧本、完善笔画、加快笔记、匹配墨水颜色并帮助创作者交易刻字资产。"},"video-art":{"id":"740","slug":"video-art","name":"录像艺术","description":"视频艺术将人工智能视频创作、化身驱动的叙述和搜索平台结合起来，帮助制作人原型化、本地化和分享电影故事。"},"illustration":{"id":"739","slug":"illustration","name":"图示","description":"插图涵盖了为UI、网站、幻灯片和广告创建、获取、编辑和销售载体视觉效果的工具，将人工智能、库、UI套件、Figma插件和MoR结合在一起。"},"crafting":{"id":"738","slug":"crafting","name":"制作","description":"您的制作指南：快速测量数学、爱好发现、DIY视频、3D动画、蜡烛工具、智能标签以及适合初学者和专业人士的规划者。"},"modeling":{"id":"737","slug":"modeling","name":"建模","description":"建模意味着构建模型-3D、数据或金融。这些工具为设计师、开发人员和分析师创建、渲染、版本、模拟和预测。"},"digital-art":{"id":"736","slug":"digital-art","name":"数字艺术","description":"数字艺术工具涵盖人工智能图像制作者、模型API和创作者商务，帮助艺术家生成视觉效果、自动化工作流程以及销售或资助他们的作品。"},"printing":{"id":"735","slug":"printing","name":"印刷","description":"印刷涵盖为创作者和小商店创建、销售和输出可印刷的文档和产品的工具--从贴纸、艺术品到期刊和讲义。"},"painting":{"id":"734","slug":"painting","name":"绘画","description":"绘画收集工具和网站来创建，学习和销售艺术：颜色选择器，艺术应用程序，画廊，DIY视频，参考搜索和NFT/物理销售。"},"coloring":{"id":"733","slug":"coloring","name":"着色","description":"着色跨越了构建和管理调色板以用于设计和品牌生成方案、编辑视觉效果、确保对比度以及为创作者组织资产的工具"},"drawing":{"id":"732","slug":"drawing","name":"绘图","description":"绘图涵盖数字草图、UI实体模型、人工智能艺术和儿童工作表-这里的工具有助于说明想法、编辑照片、故事板电影和协作。"},"social-networking":{"id":"717","slug":"social-networking","name":"社交网络","description":"社交网络通过聊天、视频、微博、聚会和广告加CRM、匹配和基础设施保护社区将人们、创作者和团队联系起来。"},"shopping":{"id":"713","slug":"shopping","name":"购物","description":"购物涵盖查找、购买和销售在线商店构建者、市场、愿望清单、奖励附加组件、支持小部件、可购物视频和搜索的工具。"},"science":{"id":"711","slug":"science","name":"科学","description":"科学工具可以帮助您搜索研究、掌握论文、分析模型、打字数学、运行量子代码并发布为研究人员和学生构建的预印本。"},"photo-video":{"id":"692","slug":"photo-video","name":"照片和视频","description":"《照片与视频》涵盖用于制作、编辑和本地化视觉效果和声音的工具-人工智能图像/视频生成、TTC配音、股票资产和搜索创作者。"},"nature-outdoors":{"id":"680","slug":"nature-outdoors","name":"自然与户外活动","description":"Nature & Outdoors提供多种工具，可识别鸟类、绘制小径地图、预订狩猎活动并建立有意识的、可持续的习惯，非常适合徒步旅行者、学生和旅行者。"},"lifestyle":{"id":"665","slug":"lifestyle","name":"生活方式","description":"生活方式工具，使生活变得顺畅：计划天气和习惯，日志增长，销售和购物商品，建立社区，并与创作者的AI助手聊天。"},"kids-parenting":{"id":"659","slug":"kids-parenting","name":"孩子与育儿","description":"儿童和育儿工具，帮助家庭睡眠、阅读、安全、屏幕时间、日常生活、日记和虚构信件-适合父母的实用选择。"},"graphics-design":{"id":"624","slug":"graphics-design","name":"图形与设计","description":"图形与设计收集了为社交、广告、应用程序和平台创建、动画、原型和运送视觉效果的工具-人工智能图像生成器、编辑器、库和网站构建器。"},"food-drink":{"id":"617","slug":"food-drink","name":"Food & Drink","description":"食品和饮料工具涵盖食谱查找器、人工智能膳食创意、烹饪机器人、卡路里追踪器和用餐记录，帮助家庭厨师、旅行者计划、烹饪和发现。"},"finance":{"id":"611","slug":"finance","name":"金融","description":"你不必成为一名会计师来处理自己的数字。这些财务应用程序是完美的计数伴侣，还有更多！ "},"extended-reality":{"id":"609","slug":"extended-reality","name":"延展实境","description":"延展实境融合AR/VR，将数字内容分层到真实地点，为城市旅游、虚拟宠物、培训、购物、旅行指南和正念健康提供动力。"},"ent