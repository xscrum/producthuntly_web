ift","description":"Facebook的Oculus希望通过虚拟现实（VR）彻底改变我们消费媒体和与世界沟通的方式。"},"slack":{"id":"22","slug":"slack","name":"松弛","description":"与大家实时聊天。与您的团队、家人和朋友一起使用它。"},"web-app":{"id":"21","slug":"web-app","name":"Web App","description":"你知道那个有所有猫照片和GIF的地方吗？它还有一些其他漂亮的东西。"},"mac":{"id":"19","slug":"mac","name":"Mac","description":"苹果电脑的传奇基础。它们易于使用，也易于喜爱。继续吧，加入收件箱的潮流。"},"windows":{"id":"18","slug":"windows","name":"Windows","description":"个人电脑改变了我们生活和工作的方式，由传奇人物比尔·盖茨创造，其愿景是“每张桌子上都放一台电脑”。"},"ebook-reader":{"id":"17","slug":"ebook-reader","name":"电子书阅读器","description":"在方便、便携的亚马逊Kindle上收集和阅读不会积灰的书籍。"},"browser-extensions":{"id":"16","slug":"browser-extensions","name":"浏览器扩展","description":"浏览器扩展是升级您的网络体验的附加组件：隐私防护、编写修复、任务捕获、实时协作、开发工具和人工智能。"},"safari-extensions":{"id":"15","slug":"safari-extensions","name":"Safari扩展","description":"Safari扩展程序为Apple浏览器添加了工具，从隐私和广告拦截到书签、笔记以及适合学生、专业人士和团队的焦点计时器。"},"linux":{"id":"13","slug":"linux","name":"Linux","description":"适合那些喜欢根据自己的喜好定制操作系统的人。Fedora、Red Hat、Ubuntu。你可以选择。"},"apple-watch":{"id":"12","slug":"apple-watch","name":"Apple Watch","description":"当您的手机上没有足够的通知来分散您的注意力时，请将它们戴在手腕上。苹果性感的可穿戴设备可能会改变你的生活。"},"card-games":{"id":"11","slug":"card-games","name":"纸牌游戏","description":"您知道纸牌游戏过去是用层压纸而不是在iPad上玩的吗？疯狂，对吧？！"},"ipad":{"id":"9","slug":"ipad","name":"iPad","description":"苹果计算天才的平板电脑，现在有多种平板电脑尺寸：Mini、Air和Pro。"},"ios":{"id":"8","slug":"ios","name":"iOS","description":"深受喜爱的“手机”改变了我们沟通、玩游戏和拍照的方式。📱"},"wii-u":{"id":"7","slug":"wii-u","name":"Wii U","description":"在任天堂的动作感应游戏机上与马里奥、塞尔达传说和神奇宝贝一起重温童年。"},"nintendo":{"id":"6","slug":"nintendo","name":"任天堂","description":"掌上游戏之王仍然占据领先地位。播放从马里奥到神奇宝贝的经典游戏，无需戴上愚蠢的眼镜，即可在3D中重新构想。"},"vita":{"id":"5","slug":"vita","name":"Vita","description":"索尼的第二款掌上电脑将主机品质的游戏直接带到您的指尖。玩Vita独占游戏，甚至直接从PS4上播放游戏。"},"playstation":{"id":"4","slug":"playstation","name":"PlayStation","description":"PlayStation收集了主机游戏必需品：大片射击游戏、复古动作、沙盒构建器、开发引擎、聊天、指南和及时的Plus游戏提醒。"},"xbox":{"id":"3","slug":"xbox","name":"Xbox","description":"微软的游戏机为您带来了《光环》和《战争机器》等精彩游戏，并兼作杀手级家庭媒体设备。"},"android":{"id":"2","slug":"android","name":"Android","description":"这个绿色小机器人是有史以来发展最快的平台之一，它生活在你的口袋里，几乎可以做任何事情。"},"pc":{"id":"1","slug":"pc","name":"PC","description":"PC将支持计算的软件和硬件分组：私人浏览、搜索、人工智能辅助、3D创建、设计、云图形处理器和适合游戏玩家、制作者和团队的游戏。"}},"ui":{"nav.home":"首页","nav.today":"今日热门","nav.categories":"分类","nav.favorites":"我的收藏","nav.about":"关于","votes":"投票","comments":"评论","home.title":"发现全球最新产品","home.subtitle":"每日更新 · 全球精选","home.description":"ProductHunt 每日热门产品，多语言翻译版本","product.visit":"访问产品","product.viewComments":"查看评论","product.intro":"产品介绍","product.related":"相关产品","product.maker":"创作者","product.info":"发布信息","product.publishedAt":"发布时间","product.publisher":"发布者","product.dataSource":"数据来源","product.dailyRank":"今日排名","product.noDescription":"暂无描述","product.featured":"精选产品","product.votes":"投票","product.comments":"评论","product.rank":"排名","product.slug":"别名","product.moreProducts":"更多产品","product.switchProducts":"← → 切换产品","product.favoriteProduct":"收藏产品","calendar.quickFilter":"快速筛选","home.tools":"工具","home.about":"关于","home.aboutText":"ProductHuntls 帮助您发现来自 ProductHunt 的最新创新产品，支持多语言翻译。","home.aboutNote":"数据每日从 ProductHunt 更新。","favorites.subtitle":"你收藏的产品会在这里显示","categories.title":"产品分类","categories.subtitle":"按分类浏览，发现你感兴趣的产品","search.placeholder":"搜索分类...","featured.topics":"热门分类","all.categories":"所有分类","by.alpha":"按字母浏览","products.count":"产品总数","followers.count":"关注者","today.new":"今日新增","related.products":"相关产品","view.all":"查看全部","empty.favorites":"还没有收藏","empty.favorites.hint":"浏览产品时点击 ❤️ 即可收藏","close":"关闭","back":"返回","about":"关于","launches":"产品发布","languages":"语言","makers":"创作者","publish.info":"发布信息","published.date":"发布时间","publisher":"发布者","data.source":"数据来源","footer.poweredBy":"基于"},"currentLang":"zh","homeHref":"/zh","categoriesHref":"/categories","cardHrefPrefix":"/categories"}]
